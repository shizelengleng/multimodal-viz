{
  "title": "学习理论流派与教育应用",
  "source": "text_file",
  "layout_hint": "hierarchical",
  "concepts": [
    {
      "id": "c1",
      "name": "学习理论",
      "description": "教育心理学的核心内容，解释学习如何发生的系统理论。",
      "category": "definition",
      "difficulty": "basic"
    },
    {
      "id": "c2",
      "name": "行为主义",
      "description": "强调可观察行为变化，认为学习是刺激-反应联结的形成过程。",
      "category": "theory",
      "difficulty": "basic"
    },
    {
      "id": "c3",
      "name": "华生",
      "description": "行为主义学习理论的创立者。",
      "category": "person",
      "difficulty": "basic"
    },
    {
      "id": "c4",
      "name": "斯金纳",
      "description": "发展操作性条件反射理论，设计程序教学机器，对教育技术影响深远。",
      "category": "person",
      "difficulty": "intermediate"
    },
    {
      "id": "c5",
      "name": "操作性条件反射",
      "description": "通过强化和惩罚塑造行为的理论，正强化增加行为频率。",
      "category": "principle",
      "difficulty": "intermediate"
    },
    {
      "id": "c6",
      "name": "认知主义",
      "description": "关注学习者内部心理过程，将学习视为信息加工和知识建构。",
      "category": "theory",
      "difficulty": "basic"
    },
    {
      "id": "c7",
      "name": "皮亚杰",
      "description": "提出认知发展阶段理论，包括感知运动、前运算、具体运算和形式运算阶段。",
      "category": "person",
      "difficulty": "intermediate"
    },
    {
      "id": "c8",
      "name": "布鲁纳",
      "description": "提出发现学习法，强调学习者主动探索知识结构。",
      "category": "person",
      "difficulty": "intermediate"
    },
    {
      "id": "c9",
      "name": "奥苏贝尔",
      "description": "提出有意义学习理论，区分机械学习和有意义学习。",
      "category": "person",
      "difficulty": "intermediate"
    },
    {
      "id": "c10",
      "name": "建构主义",
      "description": "认为知识由学习者基于已有经验主动建构，而非客观存在。",
      "category": "theory",
      "difficulty": "basic"
    },
    {
      "id": "c11",
      "name": "维果茨基",
      "description": "提出社会建构主义和最近发展区理论，强调社会文化环境的作用。",
      "category": "person",
      "difficulty": "intermediate"
    },
    {
      "id": "c12",
      "name": "最近发展区",
      "description": "教学应走在发展前面，在帮助下儿童能达到更高发展水平。",
      "category": "principle",
      "difficulty": "intermediate"
    },
    {
      "id": "c13",
      "name": "加涅",
      "description": "综合行为主义和认知主义，提出学习条件理论和学习结果分类。",
      "category": "person",
      "difficulty": "intermediate"
    },
    {
      "id": "c14",
      "name": "学习结果分类",
      "description": "将学习结果分为言语信息、智慧技能、认知策略、态度和动作技能五类。",
      "category": "definition",
      "difficulty": "advanced"
    },
    {
      "id": "c15",
      "name": "九段教学法",
      "description": "加涅提出的教学设计步骤，广泛应用于教学设计中。",
      "category": "process",
      "difficulty": "advanced"
    },
    {
      "id": "c16",
      "name": "教育技术应用",
      "description": "学习理论在程序教学、CAI、ITS、PBL等教学技术中的应用。",
      "category": "application",
      "difficulty": "intermediate"
    },
    {
      "id": "c17",
      "name": "联通主义",
      "description": "面向数字时代的学习理论，强调节点和连接的重要性。",
      "category": "theory",
      "difficulty": "advanced"
    },
    {
      "id": "c18",
      "name": "乔治·西蒙斯",
      "description": "联通主义的提出者，认为管道比内容更重要。",
      "category": "person",
      "difficulty": "advanced"
    }
  ],
