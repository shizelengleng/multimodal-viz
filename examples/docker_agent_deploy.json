{
  "title": "Docker容器本地部署AI Agent完全指南",
  "source": "text_file",
  "layout_hint": "hierarchical",
  "concepts": [
    {
      "id": "c1",
      "name": "Docker Model Runner",
      "description": "Docker推出的本地运行LLM模型的工具，兼容OpenAI API，支持多种模型拉取和调用。",
      "category": "application",
      "difficulty": "basic"
    },
    {
      "id": "c2",
      "name": "Docker MCP Gateway",
      "description": "通过Model Context Protocol连接外部工具和服务的网关组件，实现Agent与工具交互。",
      "category": "application",
      "difficulty": "intermediate"
    },
    {
      "id": "c3",
      "name": "Docker cagent",
      "description": "声明式YAML多Agent运行时，无需手写代码即可定义和运行AI Agent。",
      "category": "application",
      "difficulty": "basic"
    },
    {
      "id": "c4",
      "name": "Docker Offload",
      "description": "提供GPU加速云端环境的工具，用于提升模型推理性能。",
      "category": "application",
      "difficulty": "intermediate"
    },
    {
      "id": "c5",
      "name": "Docker Compose",
      "description": "定义和运行多容器AI应用的统一编排工具，支持一键启动完整Agent架构。",
      "category": "application",
      "difficulty": "basic"
    },
    {
      "id": "c6",
      "name": "零代码Agent方案",
      "description": "使用Docker cagent通过YAML声明式定义Agent，无需编写代码即可创建多角色Agent。",
      "category": "example",
      "difficulty": "basic"
    },
    {
      "id": "c7",
      "name": "自定义Agent方案",
      "description": "适合Python开发者，通过Docker Model Runner和HTTP请求编写自定义Agent逻辑。",
      "category": "example",
      "difficulty": "intermediate"
    },
    {
      "id": "c8",
      "name": "多服务Agent架构",
      "description": "使用Docker Compose集成模型、工具网关和Web UI的完整Agent应用方案。",
      "category": "example",
      "difficulty": "advanced"
    },
    {
      "id": "c9",
      "name": "Goose简易Agent",
      "description": "基于Goose开源框架和Docker工具链的简易AI助手方案，提供浏览器界面。",
      "category": "example",
      "difficulty": "intermediate"
    },
    {
      "id": "c10",
      "name": "MCP协议",
      "description": "Model Context Protocol，用于连接Agent与外部工具和服务的通信协议。",
      "category": "principle",
      "difficulty": "intermediate"
    },
    {
      "id": "c11",
      "name": "安全沙盒",
      "description": "Agent生成代码在隔离容器中运行的安全机制，可禁用网络防止数据泄露。",
      "category": "principle",
      "difficulty": "advanced"
    },
    {
      "id": "c12",
      "name": "混合AI模式",
      "description": "本地小模型处理常规任务，远程大模型处理复杂推理，可降低5至30倍成本。",
      "category": "principle",
      "difficulty": "advanced"
    },
    {
