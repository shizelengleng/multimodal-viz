# 多模态知识图谱可视化生成器 - API 配置
# ==========================================
# 使用步骤：
#   1. 复制此文件并重命名为 .env
#   2. 填入至少一个 API Key
#   3. 重启程序
#
# API Key 获取：
#   DeepSeek: https://platform.deepseek.com → 注册 → API Keys → 创建
#   MiMo:     https://platform.xiaomimimo.com → 注册 → API Keys → 创建

# DeepSeek API Key (推荐，性价比高，中文优化)
DEEPSEEK_API_KEY=sk-your-key-here

# MiMo API Key (备选，v2.5 多模态理解)
MIMO_API_KEY=sk-your-key-here
